/// tinyecs:modding — WIT interface for the TinyEcs component-model modding API.
///
/// Generic (not cuo-specific): mods register ECS systems + operate on the
/// shared world. Ported from wasvy (wasvy:ecs), adapted to TinyEcs:
///   - schedule variant uses cuo Stage names (no FixedUpdate)
///   - everything else mirrors the wasvy resource graph 1:1.
///
/// The NEW, component-model modding API. It does NOT replace the existing
/// Extism message-passing API (src/ClassicUO.Ecs/Modding/).
package tinyecs:modding@0.1.0;

/// The world the C# host implements to give ECS access to a WASM guest (mod).
world host {
	import app;
}

/// The world a WASM mod must implement to be driven by the host.
world guest {
	import app;
	use app.{app};

	/// Called once on load for each mod. Register systems via `app` here.
	export setup: func(app: app);
}

interface app {
	/// bevy::App equivalent — the mod's entry point to the ECS.
	resource app {
		/// Register systems into a schedule (cuo Stage).
		add-systems: func(
			schedule: schedule,
			systems: list<borrow<system>>,
		);

		/// Register an observer. `name` MUST match a guest export with signature
		/// func(entity: u64, json: string) — json is the component value for
		/// insert/remove, "" for spawn/despawn. Fired events are buffered and
		/// dispatched at a safe point (end of frame), so the callback may mutate
		/// the world through commands without re-entrancy hazards.
		add-observer: func(name: string, evt: observer-event);
	}

	/// Lifecycle/component events a mod can observe. Insert/remove carry the
	/// component type-path (must be a host-registered component).
	variant observer-event {
		spawn,
		despawn,
		insert(string),
		remove(string),
		// A host-registered custom event, by name. Fired via commands.emit-event
		// (mod) or the host's own EmitTrigger — both reach this observer.
		custom(string),
	}

	/// A system the mod defines. Name MUST match a guest export.
	resource system {
		constructor(name: string);

		/// Request a `commands` param.
		add-commands: func();

		/// Request a `query` param.
		add-query: func(query: list<query-for>);

		/// Order this system after another.
		after: func(other: borrow<system>);

		/// Order this system before another.
		before: func(other: borrow<system>);
	}

	/// Structural-change queue (spawn/despawn/insert/remove). Applied at the
	/// next sync point on the host side (cuo Commands), never raw-world.
	resource commands {
		spawn-empty: func() -> entity-commands;
		spawn: func(bundle: bundle) -> entity-commands;
		entity: func(entity: borrow<entity>) -> entity-commands;

		/// Get an entity-commands handle for an entity by its raw id (the value
		/// `entity::id` returns). Lets a mod queue edits against an entity it only
		/// holds the u64 for (e.g. one resolved via cuo:net/resolve-serial) without
		/// an `entity` handle.
		entity-by-id: func(id: u64) -> entity-commands;

		/// TYPED spawn: components cross as native records (no JSON), via the
		/// component-value variant. The core UI set is migrating off the string
		/// bundle to this. Coexists with `spawn` during the migration.
		spawn-typed: func(bundle: list<component-value>) -> entity-commands;

		/// Read a registered singleton resource as JSON ("null" if unregistered or
		/// absent). `path` is a type-path the host registry maps to a Res<T> —
		/// e.g. "cuo:engine/time", "cuo:game/context". The "change resource"
		/// capability's read half. (`resource` is a WIT keyword → param is `path`.)
		/// (Networking lives in the cuo:modding package — game-specific, not a
		/// TinyEcs/Bevy primitive.)
		resource-get: func(path: type-path) -> serialized-component;

		/// Write a registered singleton resource from JSON (no-op if unregistered
		/// or absent). Only whitelisted resources are writable.
		resource-set: func(path: type-path, value: serialized-component);

		/// Consume a mouse button this frame so host gameplay ignores it (input
		/// behaviour override). Honored everywhere the host checks
		/// MouseContext.IsConsumed. Call from a pre-update system to take the
		/// button before gameplay reads it. (Keyboard consume needs library
		/// support and is a follow-up.)
		input-consume-mouse: func(button: u8);

		/// Consume a keyboard key this frame so host gameplay ignores it (the
		/// keyboard half of input-consume-mouse). `key` is the platform key code
		/// (host casts it to its native Keys). Honored everywhere the host checks
		/// the keyboard consume flag; call from a pre-update system to take the key
		/// before gameplay reads it.
		input-consume-keyboard: func(key: u32);

		/// Emit a host-registered custom event by name (entity 0 = global). The
		/// host fires it as a typed trigger, so host systems and any mod observing
		/// `custom(name)` both receive it. No-op if `name` is not registered.
		emit-event: func(name: string, entity: u64, json: string);
	}

	/// Queued edits for a single entity.
	resource entity-commands {
		id: func() -> entity;
		insert: func(bundle: bundle);
		/// TYPED insert (native records, no JSON).
		insert-typed: func(bundle: list<component-value>);
		remove: func(bundle: bundle-types);

		/// Add `child` under THIS entity at `index` (pass a large value to append).
		/// Called on the parent's entity-commands. Used to attach mod UI into an
		/// existing gump (e.g. add a button under the topbar group).
		add-child: func(child: borrow<entity>, index: u32);

		despawn: func();
	}

	/// An entity identifier handle.
	resource entity {
		/// The raw entity id (a stable u64). Pair with commands::entity-by-id to
		/// queue edits against an entity a mod stored the id for across frames.
		id: func() -> u64;

		/// Parent in the UI/scene tree (none for a root). Lets mods navigate
		/// any gump generically — no per-gump host cooperation.
		parent: func() -> option<entity>;

		/// Direct children in the UI/scene tree.
		children: func() -> list<entity>;

		/// Read a registered component off this entity by type-path; the JSON
		/// string "null" if absent. Lets a mod inspect traversed nodes.
		get: func(component: type-path) -> serialized-component;
	}

	/// A query system param — iterate matched entities.
	resource query {
		iter: func() -> option<query-result>;
	}

	/// One row of a query iteration.
	resource query-result {
		entity: func() -> entity;
		/// Component at the declared index (filters do not count).
		component: func(index: component-index) -> component;
	}

	/// A component view on a query row.
	resource component {
		get: func() -> serialized-component;
		/// Traps if this component was not declared mutable.
		set: func(value: serialized-component);

		/// TYPED write (native record via component-value, no JSON). Typed READ
		/// (a component-value RETURN) is NOT offered: the fork runtime mishandles
		/// variant-return payload ownership (native crash) — codegen is fixed but
		/// the runtime is not. Read via `get` (JSON) until that's resolved.
		set-typed: func(value: component-value);
	}

	/// A fully-qualified type name (the host registry maps this to an EcsID).
	type type-path = string;

	/// JSON-serialized component payload crossing the boundary.
	///
	/// A JSON string (NOT list<u8>): the host (de)serializes via the type
	/// registry. Kept as a string because the fork's source generator
	/// mislowers a `list` element nested inside a `tuple` inside a `list`
	/// (the `bundle` shape) — strings take the working scalar path.
	type serialized-component = string;

	/// (type-path, serialized) pairs.
	type bundle = list<tuple<type-path, serialized-component>>;

	/// type-paths only (for removal).
	type bundle-types = list<type-path>;

	/// Up to 255 components per query.
	type component-index = u8;

	// ── Typed component records (the no-JSON path) ────────────────────────────
	// Each mirrors a host component's serializable shape. Enum fields cross as
	// WIT enums (the host casts the discriminant). Adding a component here = a
	// new variant case + a host converter + regen (the cost of going typed vs
	// the string registry).

	/// A length value. kind: 0=auto, 1=px, 2=percent (ValType).
	record val { kind: u8, value: f32 }

	/// Edge insets (Node padding / border).
	record ui-rect { left: val, right: val, top: val, bottom: val }

	/// RGBA, 0-255 floats (Clay.Color).
	record color { r: f32, g: f32, b: f32, a: f32 }

	/// Bevy.UI Node layout enums. Case order = host enum order (Val.cs) = the
	/// former u8 values, so the host casts the discriminant straight across.
	enum display          { flex, none }
	enum position-type    { relative, absolute }
	enum overflow         { visible, clip, scroll }
	enum flex-direction   { row, column }
	enum justify-content  { start, center, end }
	enum align-items      { start, center, end }

	/// Bevy.UI Node (layout).
	record node-rec {
		display: display,
		position-type: position-type,
		overflow: overflow,
		flex-direction: flex-direction,
		justify-content: justify-content,
		align-items: align-items,
		width: val, height: val,
		min-width: val, min-height: val,
		max-width: val, max-height: val,
		left: val, top: val, right: val, bottom: val,
		padding: ui-rect,
		border: ui-rect,
		gap: val,
		aspect-ratio: f32,
	}

	record text-rec { value: string }
	record text-font-rec { font-id: u16, size: u16 }
	record z-rec { value: s32 }
	record name-rec { value: string }

	/// Typed component payloads (core UI set). Markers carry no payload. The
	/// variant case IS the component type (no type-path needed for spawn/insert).
	variant component-value {
		node(node-rec),
		text(text-rec),
		text-font(text-font-rec),
		text-color(color),
		bg-color(color),
		interaction(u8),
		global-z(z-rec),
		ui-name(name-rec),
		movable,
		no-window-drag,
		contains-by-bounds,
	}

	/// cuo Stage selection.
	variant schedule {
		/// Runs once when a mod is first loaded (not Stage.Startup).
		mod-startup,
		first,
		pre-update,
		update,
		post-update,
		last,
		custom(string),
	}

	/// Query term — order defines component index for query-result::component.
	variant query-for {
		ref(type-path),
		mut(type-path),
		%with(type-path),
		without(type-path),
	}
}
